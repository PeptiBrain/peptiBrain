# Copia este archivo a .env.local y completa los valores reales.
# .env.local NUNCA se sube a git (ya está en .gitignore).

# Públicas — seguras de exponer al navegador (protegidas por RLS, no son secretas)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Servidor — JAMÁS con prefijo NEXT_PUBLIC_, JAMÁS en el frontend
SUPABASE_SECRET_KEY=

# Hotmart — token secreto del webhook (Configuración del producto → Webhook)
HOTMART_HOTTOK=

# Mixpanel — el project token es público por diseño (va en el bundle del navegador)
NEXT_PUBLIC_MIXPANEL_TOKEN=

# Cloudflare Turnstile — el Site Key es público (va en el navegador).
# El Secret Key NO va aquí: se configura directo en Supabase (Authentication → Attack Protection).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Asistente IA (Premium) — API key de OpenRouter (openrouter.ai/keys). Gratis:
# 50 mensajes/día sin tarjeta, 1000/día si cargas $10 de saldo (no se gasta, solo
# desbloquea el límite). Sin esto configurado, el Asistente responde "no disponible"
# pero el resto de la app funciona normal.
OPENROUTER_API_KEY=
# Opcional: modelo a usar (por defecto un modelo gratis de OpenRouter). Para cambiar
# a uno de pago barato, pon el ID exacto de openrouter.ai/models (ej: google/gemini-2.5-flash).
ASSISTANT_AI_MODEL=openai/gpt-oss-20b:free
# Kill-switch de costo: máximo de mensajes de TODOS los usuarios juntos por día
# (protege contra factura sorpresa). Por defecto 500 si no se pone nada.
ASSISTANT_GLOBAL_DAILY_LIMIT=500

# Aviso automático cuando se activa el kill-switch del Asistente (opcional pero
# recomendado). Requiere una cuenta de Resend (ya usas Resend para los emails de
# registro) y tu correo para recibir el aviso.
RESEND_API_KEY=
OWNER_ALERT_EMAIL=

# Oferta de fundadores — pago único "de por vida", primeros N cupos. Todo opcional:
# sin esto configurado, la tarjeta de la oferta simplemente no aparece en el paywall.
# 1. En Hotmart: crea un producto/oferta de pago ÚNICO (NO suscripción) al precio
#    que quieras cobrar de por vida (ej. $99).
# 2. Pega aquí el código de esa oferta (NEXT_PUBLIC porque se usa también en el navegador
#    para armar el link de checkout — no es un secreto, es solo un identificador de oferta).
NEXT_PUBLIC_HOTMART_OFFER_LIFETIME=
# El precio que se MUESTRA (debe coincidir con lo que configuraste en Hotmart arriba).
NEXT_PUBLIC_LIFETIME_PRICE=99
# Cuántos cupos hay en total — una vez vendidos todos, la oferta desaparece del
# paywall para siempre (el conteo real se calcula solo con profiles.is_lifetime).
NEXT_PUBLIC_LIFETIME_TOTAL_SLOTS=100
